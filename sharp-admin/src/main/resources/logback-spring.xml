<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="60 seconds" debug="false">
    <!--
    <include resource="org/springframework/boot/logging/logback.xml/base.xml" />
     -->
    <!-- 日志最大的历史 30天 -->
    <property name="maxHistory" value="30"/>
    <property name="maxFileSize" value="64MB"/>

    <springProfile name="dev">
        <include resource="logback/logback-dev.xml"/>
    </springProfile>
    <springProfile name="test">
        <include resource="logback/logback-test.xml"/>
    </springProfile>
    <springProfile name="prod">
        <include resource="logback/logback-prod.xml"/>
    </springProfile>
    <springProfile name="docker-prod">
        <include resource="logback/logback-prod.xml"/>
    </springProfile>
    <springProfile name="dev-prod">
        <include resource="logback/logback-dev.xml"/>
    </springProfile>

    <!--如果没有找到 profile 兜底输出到控制台-->
    <!-- 一旦你提供了 logback-spring.xml，Spring Boot 的默认配置就会被完全接管，默认的 ConsoleAppender 也不再自动加载。-->
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %contextName [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset> <!-- 此处设置字符集 -->
        </encoder>
    </appender>

    <root level="DEBUG">
        <appender-ref ref="console" />
    </root>

    <!--idea 可以运行，bash运行找不到-->
<!--    <include resource="logback.xml/logback.xml-${spring.profiles.active}.xml"/>-->
</configuration>